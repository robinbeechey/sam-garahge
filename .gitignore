# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
.turbo/

# Test coverage
coverage/
packages/cli/coverage.out

# Generated Go binaries
packages/cli/bin/

# Environment files
.env
.env.local
.env.*.local
.env.mock
.dev.vars

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Wrangler
.wrangler/

# Temporary files
*.tmp
*.temp
.cache/

# Codex local state (CODEX_HOME defaults to ~/.codex)
# Note: .codex/config.toml is NOT ignored — it's project-scoped config that should be tracked
.codex/auth.json
.codex/.credentials.json
.codex/history.jsonl
.codex/models_cache.json
.codex/.personality_migration
.codex/version.json
.codex/log/
.codex/sessions/
.codex/tmp/
# Playwright audit screenshots write under apps/web cwd, not the repo root
**/.codex/tmp/

# Ephemeral agent scratch space — screenshots, debug dumps, downloads, notes.
# Anything that should NOT be committed goes in .tmp/ (see .tmp/README.md).
.tmp/
!.tmp/README.md

# Playwright MCP session artifacts (page snapshots, login scripts)
.playwright-mcp/

# SAM library downloads (download_library_file MCP tool target — canonical copies live in the platform library)
.library/

# /do workflow state (ephemeral, per-session)
.do-state.md

# /workflow orchestrator state (ephemeral, per-session)
.workflow-state.md
