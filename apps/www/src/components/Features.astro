---
const features = [
  {
    icon: 'agents',
    title: 'Multi-Agent Support',
    description: 'Claude Code, Codex, Gemini CLI, Mistral Vibe, or OpenCode — pick the right agent for the job. Bring your own API keys.',
  },
  {
    icon: 'shield',
    title: 'Bring Your Own Cloud',
    description: 'Your code runs on your VMs. Credentials encrypted per-user. You control costs, regions, and data residency.',
  },
  {
    icon: 'container',
    title: 'Real Dev Environments',
    description: 'Agents work inside your repo\'s devcontainer — same toolchains and test runners your team uses.',
  },
  {
    icon: 'eye',
    title: 'Structured Visibility',
    description: 'Watch agents in real time — tool calls, file diffs, permission requests. Not raw terminal output.',
  },
  {
    icon: 'chat',
    title: 'Chat-Driven Tasks',
    description: 'Describe what you need. SAM provisions a VM, builds the devcontainer, and runs the agent.',
  },
  {
    icon: 'code',
    title: 'Open Source & Self-Hostable',
    description: 'AGPL-3.0 licensed. Self-host on Cloudflare\'s free tier. No vendor lock-in.',
  },
];

const iconPaths: Record<string, string[]> = {
  agents: [
    'M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2',
    'M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8z',
    'M22 21v-2a4 4 0 0 0-3-3.87',
    'M16 3.13a4 4 0 0 1 0 7.75',
  ],
  shield: [
    'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z',
  ],
  container: [
    'M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z',
    'M3.27 6.96L12 12.01l8.73-5.05',
    'M12 22.08V12',
  ],
  eye: [
    'M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z',
    'M12 9a3 3 0 1 0 0 6 3 3 0 0 0 0-6z',
  ],
  chat: [
    'M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z',
  ],
  code: [
    'M16 18l6-6-6-6',
    'M8 6l-6 6 6 6',
  ],
};
---

<section id="features" class="section">
  <div class="container">
    <div class="features-header animate-on-scroll">
      <span class="section-label">Features</span>
      <h2 class="section-title">Agent workflows<br />on infrastructure you own</h2>
      <p class="section-subtitle">
        Everything you need to run coding agents on your own cloud.
      </p>
    </div>

    <div class="features-grid">
      {features.map((feature, i) => (
        <div class="feature-card animate-on-scroll" style={`transition-delay: ${i * 80}ms`}>
          <div class="feature-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              {iconPaths[feature.icon].map((d) => (
                <path d={d} />
              ))}
            </svg>
          </div>
          <h3 class="feature-title">{feature.title}</h3>
          <p class="feature-desc">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features-header {
    text-align: center;
    margin-bottom: 64px;
  }

  .features-header .section-subtitle {
    margin-left: auto;
    margin-right: auto;
  }

  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  @media (min-width: 640px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .features-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .feature-card {
    padding: 32px;
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--glass-shadow);
    transition: border-color 0.3s, box-shadow 0.3s, opacity 0.6s ease, transform 0.6s ease;
  }

  .feature-card:hover {
    border-color: var(--glass-border-hover);
    box-shadow: var(--glass-shadow), 0 0 40px rgba(22, 163, 74, 0.15), 0 0 80px rgba(22, 163, 74, 0.05);
  }

  .feature-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: var(--radius-md);
    background: rgba(22, 163, 74, 0.12);
    border: 1px solid rgba(22, 163, 74, 0.15);
    box-shadow: 0 0 16px rgba(22, 163, 74, 0.1);
    color: var(--color-accent);
    margin-bottom: 20px;
  }

  .feature-title {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-fg-primary);
    margin-bottom: 8px;
  }

  .feature-desc {
    font-size: 0.9375rem;
    color: var(--color-fg-muted);
    line-height: 1.6;
  }
</style>
