---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import { integrations, getBySlug, getRelated } from '../../data/integrations';
import type { Integration } from '../../data/integrations';

export function getStaticPaths() {
  return integrations.map((integration) => ({
    params: { slug: integration.slug },
    props: { integration },
  }));
}

interface Props {
  integration: Integration;
}

const { integration } = Astro.props;
const related = getRelated(integration);

const baseDomain = import.meta.env.PUBLIC_BASE_DOMAIN || 'simple-agent-manager.org';
const siteUrl = `https://www.${baseDomain}`;
const appUrl = `https://app.${baseDomain}`;

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Integrations', item: `${siteUrl}/integrations/` },
    { '@type': 'ListItem', position: 3, name: integration.name },
  ],
};

const faqJsonLd = integration.faq.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: integration.faq.map(({ question, answer }) => ({
    '@type': 'Question',
    name: question,
    acceptedAnswer: { '@type': 'Answer', text: answer },
  })),
} : null;

const howToJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: `How to use ${integration.name} with SAM`,
  step: integration.howItWorks.map(({ step, description }, i) => ({
    '@type': 'HowToStep',
    position: i + 1,
    name: step,
    text: description,
  })),
};

const stepIcons = [
  // 1. Connect/Configure
  ['M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z'],
  // 2. Select/Choose
  ['M22 11.08V12a10 10 0 1 1-5.93-9.14', 'M22 4L12 14.01l-3-3'],
  // 3. Run/Execute
  ['M13 2L3 14h9l-1 8 10-12h-9l1-8'],
  // 4. Result/Review
  ['M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z', 'M14 2v6h6', 'M16 13H8', 'M16 17H8', 'M10 9H8'],
];

const useCaseIcons = [
  // Lightning bolt
  ['M13 2L3 14h9l-1 8 10-12h-9l1-8'],
  // Layers
  ['M12 2L2 7l10 5 10-5-10-5z', 'M2 17l10 5 10-5', 'M2 12l10 5 10-5'],
  // Wrench
  ['M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z'],
];
---

<Base title={integration.seoTitle} description={integration.seoDescription}>
  <Header />
  <main>
    <!-- Breadcrumb -->
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <div class="container">
        <ol class="breadcrumb-list">
          <li><a href="/">Home</a></li>
          <li><a href="/integrations/">Integrations</a></li>
          <li aria-current="page">{integration.name}</li>
        </ol>
      </div>
    </nav>

    <!-- Hero -->
    <section class="detail-hero">
      <div class="detail-glow" aria-hidden="true"></div>
      <div class="container detail-hero-content">
        <div class="hero-logo animate-on-scroll">
          <img src={integration.logoPath} alt={`${integration.name} logo`} width="72" height="72" />
        </div>
        <span class="hero-category animate-on-scroll">{integration.categoryLabel}</span>
        <h1 class="detail-title animate-on-scroll">{integration.tagline}</h1>
        <p class="detail-subtitle animate-on-scroll">{integration.description}</p>
        <div class="hero-actions animate-on-scroll">
          <a href={appUrl} class="btn-hero btn-hero-primary">
            Get Started with {integration.shortName || integration.name}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a href={integration.externalUrl} class="btn-hero btn-hero-secondary" target="_blank" rel="noopener noreferrer">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            {integration.name} Docs
          </a>
        </div>
        {integration.models && (
          <div class="model-badges animate-on-scroll">
            {integration.models.map((model) => (
              <span class="model-badge">{model}</span>
            ))}
          </div>
        )}
      </div>
    </section>

    <!-- Features -->
    <section class="section" id="features">
      <div class="container">
        <div class="section-header animate-on-scroll">
          <span class="section-label">Features</span>
          <h2 class="section-title">Why use {integration.shortName || integration.name} with SAM</h2>
        </div>
        <div class="features-grid">
          {integration.features.map((feature, i) => (
            <div class="feature-card animate-on-scroll" style={`transition-delay: ${i * 80}ms`}>
              <div class="feature-dot" aria-hidden="true"></div>
              <h3 class="feature-title">{feature.title}</h3>
              <p class="feature-desc">{feature.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <hr class="divider" />

    <!-- How It Works -->
    <section class="section" id="how-it-works">
      <div class="container">
        <div class="section-header animate-on-scroll">
          <span class="section-label">How It Works</span>
          <h2 class="section-title">Get started in four steps</h2>
        </div>
        <div class="steps-grid">
          {integration.howItWorks.map((item, i) => (
            <div class="step-card animate-on-scroll" style={`transition-delay: ${i * 100}ms`}>
              <div class="step-number">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  {stepIcons[i]?.map((d) => <path d={d} />)}
                </svg>
              </div>
              <div class="step-content">
                <span class="step-label">Step {i + 1}</span>
                <h3 class="step-title">{item.step}</h3>
                <p class="step-desc">{item.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <hr class="divider" />

    <!-- Use Cases -->
    <section class="section" id="use-cases">
      <div class="container">
        <div class="section-header animate-on-scroll">
          <span class="section-label">Use Cases</span>
          <h2 class="section-title">What you can build</h2>
        </div>
        <div class="usecases-grid">
          {integration.useCases.map((uc, i) => (
            <div class="usecase-card animate-on-scroll" style={`transition-delay: ${i * 100}ms`}>
              <div class="usecase-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  {useCaseIcons[i % useCaseIcons.length]?.map((d) => <path d={d} />)}
                </svg>
              </div>
              <h3 class="usecase-title">{uc.title}</h3>
              <p class="usecase-desc">{uc.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <hr class="divider" />

    <!-- FAQ -->
    {integration.faq.length > 0 && (
      <section class="section" id="faq">
        <div class="container">
          <div class="section-header animate-on-scroll">
            <span class="section-label">FAQ</span>
            <h2 class="section-title">Frequently asked questions</h2>
          </div>
          <div class="faq-list">
            {integration.faq.map((item, i) => (
              <details class="faq-item animate-on-scroll" style={`transition-delay: ${i * 60}ms`}>
                <summary class="faq-question">{item.question}</summary>
                <p class="faq-answer">{item.answer}</p>
              </details>
            ))}
          </div>
        </div>
      </section>
    )}

    <hr class="divider" />

    <!-- Related Integrations -->
    {related.length > 0 && (
      <section class="section" id="related">
        <div class="container">
          <div class="section-header animate-on-scroll">
            <span class="section-label">Related</span>
            <h2 class="section-title">Works great with</h2>
          </div>
          <div class="related-grid">
            {related.map((rel, i) => (
              <a href={`/integrations/${rel.slug}/`} class="related-card animate-on-scroll" style={`transition-delay: ${i * 80}ms`}>
                <div class="related-logo">
                  <img src={rel.logoPath} alt={`${rel.name} logo`} width="36" height="36" loading="lazy" />
                </div>
                <div class="related-info">
                  <h3 class="related-name">{rel.name}</h3>
                  <span class="related-category">{rel.categoryLabel}</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- CTA -->
    <section class="detail-cta">
      <div class="container">
        <div class="detail-cta-content animate-on-scroll">
          <h2 class="cta-title">Start running {integration.shortName || integration.name} on your infrastructure</h2>
          <p class="cta-subtitle">
            Self-host on low-cost Cloudflare Workers. Bring your own cloud. Your agents, your code.
          </p>
          <div class="cta-actions">
            <a href={appUrl} class="btn-cta btn-cta-primary">
              Get Started
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
            <a href="/integrations/" class="btn-cta btn-cta-secondary">All Integrations</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
      <div class="container footer-inner">
        <div class="footer-brand">
          <svg width="24" height="24" viewBox="0 0 512 512" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect width="512" height="512" rx="112" fill="#0b1110"/>
            <rect x="56" y="56" width="400" height="400" rx="80" fill="#13201d" stroke="#29423b" stroke-width="8"/>
            <path d="M154 208L226 256L154 304" stroke="#16a34a" stroke-width="30" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M270 318H360" stroke="#e6f2ee" stroke-width="26" stroke-linecap="round"/>
          </svg>
          <span>Simple Agent Manager</span>
        </div>
        <div class="footer-links">
          <a href="/">Home</a>
          <a href="/blog/">Blog</a>
          <a href="/integrations/">Integrations</a>
          <a href="https://github.com/raphaeltm/simple-agent-manager" target="_blank" rel="noopener noreferrer">GitHub</a>
        </div>
        <p class="footer-copy">&copy; {new Date().getFullYear()} Simple Agent Manager. Open source under AGPL-3.0.</p>
      </div>
    </footer>
  </main>

  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  {faqJsonLd && <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />}
  <script type="application/ld+json" set:html={JSON.stringify(howToJsonLd)} />
</Base>

<style>
  /* Breadcrumb */
  .breadcrumb {
    padding-top: calc(var(--header-height) + 16px);
  }

  .breadcrumb-list {
    display: flex;
    align-items: center;
    gap: 8px;
    list-style: none;
    padding: 0;
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  .breadcrumb-list li {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--color-fg-dim);
  }

  .breadcrumb-list li:not(:last-child)::after {
    content: '/';
    color: var(--color-fg-dim);
  }

  .breadcrumb-list a {
    color: var(--color-fg-muted);
  }

  .breadcrumb-list a:hover {
    color: var(--color-fg-primary);
  }

  /* Detail Hero */
  .detail-hero {
    position: relative;
    padding: 40px 0 60px;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .detail-hero { padding: 60px 0 80px; }
  }

  .detail-glow {
    position: absolute;
    top: -200px;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 600px;
    background: radial-gradient(ellipse at center, var(--color-accent-glow) 0%, transparent 70%);
    pointer-events: none;
    animation: glow-pulse 6s ease-in-out infinite;
  }

  .detail-hero-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .hero-logo {
    width: 80px;
    height: 80px;
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    margin-bottom: 24px;
    overflow: hidden;
  }

  .hero-category {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: 16px;
  }

  .detail-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4.5vw, 3rem);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--color-fg-primary);
    margin-bottom: 20px;
    max-width: 720px;
  }

  .detail-subtitle {
    font-size: clamp(0.9375rem, 1.5vw, 1.125rem);
    color: var(--color-fg-muted);
    max-width: 640px;
    line-height: 1.7;
    margin-bottom: 32px;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
    margin-bottom: 24px;
  }

  .btn-hero {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 500;
    padding: 12px 28px;
    border-radius: var(--radius-md);
    transition: all 0.2s;
  }

  .btn-hero-primary {
    background: var(--color-accent);
    color: white;
  }

  .btn-hero-primary:hover {
    background: var(--color-accent-hover);
    color: white;
    transform: translateY(-1px);
  }

  .btn-hero-secondary {
    background: var(--color-bg-surface);
    color: var(--color-fg-primary);
    border: 1px solid var(--color-border);
  }

  .btn-hero-secondary:hover {
    background: var(--color-bg-surface-hover);
    color: var(--color-fg-primary);
    border-color: var(--color-fg-dim);
  }

  .model-badges {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
  }

  .model-badge {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-fg-muted);
    border: 1px solid var(--color-border);
    padding: 4px 12px;
    border-radius: 100px;
    letter-spacing: 0.02em;
  }

  /* Section common */
  .section {
    padding: 80px 0;
  }

  @media (min-width: 768px) {
    .section { padding: 100px 0; }
  }

  .section-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .section-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: 12px;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 600;
    color: var(--color-fg-primary);
    line-height: 1.2;
  }

  .divider {
    border: none;
    border-top: 1px solid var(--color-border-subtle);
    margin: 0;
  }

  /* Features Grid */
  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  @media (min-width: 640px) {
    .features-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .feature-card {
    padding: 28px;
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-lg);
    transition: border-color 0.3s, box-shadow 0.3s, opacity 0.6s ease, transform 0.6s ease;
  }

  .feature-card:hover {
    border-color: var(--color-border);
    box-shadow: 0 0 40px var(--color-accent-glow);
  }

  .feature-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-accent);
    margin-bottom: 16px;
    box-shadow: 0 0 12px var(--color-accent-glow);
  }

  .feature-title {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-fg-primary);
    margin-bottom: 8px;
  }

  .feature-desc {
    font-size: 0.9375rem;
    color: var(--color-fg-muted);
    line-height: 1.6;
  }

  /* Steps Grid */
  .steps-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    max-width: 720px;
    margin: 0 auto;
  }

  @media (min-width: 640px) {
    .steps-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .step-card {
    display: flex;
    gap: 16px;
    padding: 24px;
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-lg);
    transition: border-color 0.3s, opacity 0.6s ease, transform 0.6s ease;
  }

  .step-card:hover {
    border-color: var(--color-border);
  }

  .step-number {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-md);
    background: var(--color-accent-glow);
    color: var(--color-accent);
  }

  .step-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin-bottom: 4px;
    display: block;
  }

  .step-title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-fg-primary);
    margin-bottom: 4px;
  }

  .step-desc {
    font-size: 0.875rem;
    color: var(--color-fg-muted);
    line-height: 1.5;
  }

  /* Use Cases */
  .usecases-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  @media (min-width: 768px) {
    .usecases-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .usecase-card {
    padding: 28px;
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-lg);
    transition: border-color 0.3s, box-shadow 0.3s, opacity 0.6s ease, transform 0.6s ease;
  }

  .usecase-card:hover {
    border-color: var(--color-border);
    box-shadow: 0 0 40px var(--color-accent-glow);
  }

  .usecase-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-md);
    background: var(--color-accent-glow);
    color: var(--color-accent);
    margin-bottom: 16px;
  }

  .usecase-title {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-fg-primary);
    margin-bottom: 8px;
  }

  .usecase-desc {
    font-size: 0.9375rem;
    color: var(--color-fg-muted);
    line-height: 1.6;
  }

  /* FAQ */
  .faq-list {
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .faq-item {
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-md);
    transition: border-color 0.3s, opacity 0.6s ease, transform 0.6s ease;
  }

  .faq-item:hover {
    border-color: var(--color-border);
  }

  .faq-item[open] {
    border-color: var(--color-border);
  }

  .faq-question {
    padding: 20px 24px;
    cursor: pointer;
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-fg-primary);
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-question::after {
    content: '+';
    font-size: 1.25rem;
    color: var(--color-fg-dim);
    transition: transform 0.2s;
    flex-shrink: 0;
    margin-left: 16px;
  }

  .faq-item[open] .faq-question::after {
    transform: rotate(45deg);
  }

  .faq-answer {
    padding: 0 24px 20px;
    font-size: 0.9375rem;
    color: var(--color-fg-muted);
    line-height: 1.7;
  }

  /* Related */
  .related-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
    max-width: 720px;
    margin: 0 auto;
  }

  @media (min-width: 640px) {
    .related-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .related-card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px;
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-lg);
    transition: border-color 0.3s, box-shadow 0.3s, transform 0.2s, opacity 0.6s ease;
    text-decoration: none;
    color: inherit;
  }

  .related-card:hover {
    border-color: var(--color-border);
