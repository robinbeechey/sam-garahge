    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--color-bg-inset);
    padding: 1px 5px;
    border-radius: 4px;
  }

  /* Callouts */
  .sh-callout {
    border-radius: var(--radius-md);
    padding: 14px 18px;
    font-size: 0.9rem;
    line-height: 1.6;
    margin: 20px 0;
