# Multi-Terminal UI Configuration

# Maximum number of concurrent terminal sessions (default: 10)
VITE_MAX_TERMINAL_SESSIONS=10

# Tab switch animation duration in milliseconds (default: 200)
VITE_TAB_SWITCH_ANIMATION_MS=200

# Terminal scrollback buffer size in lines (default: 1000)
VITE_TERMINAL_SCROLLBACK_LINES=1000

# Feature flag for multi-terminal UI (default: false)
# Set to true to enable multi-terminal tabs
VITE_FEATURE_MULTI_TERMINAL=false

# Base domain for the application (set to your domain when self-hosting)
VITE_BASE_DOMAIN=example.com

# API URL (if different from default)
VITE_API_URL=

# WebSocket protocol (ws or wss)
VITE_WS_PROTOCOL=wss

# Public website URL for the "Learn more" link on the sign-in page
# Defaults to https://simple-agent-manager.org — set this to your own marketing
# site URL when self-hosting, or leave empty to use the default
VITE_PUBLIC_WEBSITE_URL=

# Debug mode
VITE_DEBUG=false

# Command palette search limits
# Maximum number of projects fetched for the command palette (default: 50)
VITE_CMD_PALETTE_PROJECT_FETCH_LIMIT=50

# Maximum number of chat sessions fetched per project for the command palette (default: 20)
VITE_CMD_PALETTE_CHAT_FETCH_LIMIT=20

# Maximum number of results shown per category in the command palette (default: 10)
VITE_CMD_PALETTE_MAX_RESULTS_PER_CATEGORY=10

# File preview size thresholds (image rendering in file browser and chat)
# VITE_FILE_PREVIEW_INLINE_MAX_BYTES=10485760   # Inline render threshold (default: 10MB)
# VITE_FILE_PREVIEW_LOAD_MAX_BYTES=52428800     # Click-to-load threshold; above this is download-only (default: 50MB)

# Analytics geo map TopoJSON URL — override for CSP-strict or air-gapped deployments
# VITE_GEO_TOPOJSON_URL=https://cdn.jsdelivr.net/npm/world-atlas@2/countries-110m.json

# Prompt template for executing an idea (use {ideaId} as placeholder)
# VITE_EXECUTE_IDEA_PROMPT_TEMPLATE=Read idea {ideaId} using the get_idea tool for full context, then execute it using the /do skill.

# WebSocket heartbeat timing — must match server-side ACP_PING_INTERVAL / ACP_PONG_TIMEOUT on the VM agent
# VITE_WS_PING_INTERVAL_MS=30000   # Interval between JSON ping messages (default: 30s)
# VITE_WS_PONG_TIMEOUT_MS=10000    # Deadline for pong response before force-close (default: 10s)

# ACP recovery — auto-recover when agent connection gives up while session is active
# VITE_ACP_RECOVERY_DELAY_MS=5000       # Initial delay before first recovery attempt (default: 5s)
# VITE_ACP_RECOVERY_INTERVAL_MS=30000   # Interval between subsequent recovery retries (default: 30s)
# VITE_ACP_RECOVERY_MAX_ATTEMPTS=10     # Max recovery attempts before giving up (default: 10)

# Connection banner debounce — suppress "Reconnecting..." for brief WebSocket blips
# VITE_RECONNECT_BANNER_DELAY_MS=3000   # Delay before showing reconnecting banner (default: 3s)