{
  "name": "@simple-agent-manager/web",
  "version": "0.1.0",
  "private": true,
  "description": "Control plane UI for Simple Agent Manager",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "dev:mock": "vite",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit && tsc --project tsconfig.sw.json --noEmit",
    "lint": "eslint 'src/**/*.{ts,tsx}' 'tests/**/*.{ts,tsx}'",
    "deploy": "pnpm build && wrangler pages deploy dist",
    "deploy:staging": "pnpm build && wrangler pages deploy dist --env staging"
  },
  "dependencies": {
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
