    "@simple-agent-manager/shared": "workspace:*",
    "@simple-agent-manager/terminal": "workspace:*",
    "@simple-agent-manager/ui": "workspace:*",
    "@tailwindcss/vite": "4.2.3",
    "@tanstack/react-query": "^5.101.2",
    "@xyflow/react": "12.10.2",
    "better-auth": "catalog:",
    "d3-scale": "4.0.2",
    "dagre": "0.8.5",
    "dompurify": "3.4.11",
    "lucide-react": "catalog:",
    "mermaid": "11.14.0",
    "prism-react-renderer": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-markdown": "catalog:",
    "react-router": "catalog:",
    "react-simple-maps": "3.0.0",
