# Local development configuration

# Wrangler port (default: 8787)
WRANGLER_PORT=8787

# Base domain used for app/api/ws-vhost URL construction
BASE_DOMAIN=workspaces.example.com

# Local development secrets (optional, for testing auth)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY=

# Optional GitLab OAuth fallback (runtime setup/admin config takes precedence)
# GITLAB_HOST=https://gitlab.com
# GITLAB_CLIENT_ID=
# GITLAB_CLIENT_SECRET=

# Cloudflare credentials (for DNS, Origin CA certificate issuance, and optional managed registry cache)
# Requires Account → SSL and Certificates → Edit for per-node Origin CA certificates.
# CF_API_TOKEN=
# CF_AIG_TOKEN=
# CF_ACCOUNT_ID=
# CF_ZONE_ID=

# Optional narrower credentials for Cloudflare managed devcontainer cache
# DEVCONTAINER_CACHE_CLOUDFLARE_API_TOKEN=
# DEVCONTAINER_CACHE_CLOUDFLARE_ACCOUNT_ID=
# DEVCONTAINER_CACHE_REGISTRY_HOST=registry.cloudflare.com
# DEVCONTAINER_CACHE_REPOSITORY_PREFIX=sam-
# DEVCONTAINER_CACHE_CREDENTIAL_EXPIRATION_MINUTES=120

# Security keys (optional locally; production deploys auto-generate them with Pulumi)
# ENCRYPTION_KEY=       # Shared fallback key — used when purpose-specific keys below are not set
# JWT_PRIVATE_KEY=
# JWT_PUBLIC_KEY=
# DEPLOY_SIGNING_PRIVATE_KEY=   # Base64 Ed25519 private key for signed deployment apply payloads
# DEPLOY_SIGNING_PUBLIC_KEY=    # Base64 Ed25519 public key delivered to deployment nodes

# Purpose-specific secret overrides (recommended for production)
# When set, these take precedence over ENCRYPTION_KEY for their respective domain.
# When unset, ENCRYPTION_KEY is used as a backwards-compatible fallback.
# BETTER_AUTH_SECRET=            # BetterAuth session management (cookie signing/encryption)
# CREDENTIAL_ENCRYPTION_KEY=    # AES-GCM encryption of user cloud credentials (Hetzner tokens, etc.)
# GITHUB_WEBHOOK_SECRET=        # GitHub webhook HMAC-SHA256 signature verification

# NOTE: Hetzner tokens are NOT platform secrets.
# Users provide their own Hetzner API tokens through the Settings UI.
# These are stored encrypted (per-user) in the database.

# Cloudflare Container instant sessions
# Generated deployment environments default this to true. Set false to force
# profile/runtime resolution back to cloud VMs.
# CF_CONTAINER_ENABLED=true
# CF_CONTAINER_SLEEP_AFTER=10m
# CF_CONTAINER_VM_AGENT_PORT=8080
# CF_CONTAINER_PORT_READY_TIMEOUT_MS=30000
# CF_CONTAINER_WORKSPACE_BASE_DIR=/workspaces

# User approval / invite-only mode
# When "true", new users require admin approval before accessing the platform.
# The first user to register automatically becomes superadmin.
# REQUIRE_APPROVAL=true

# API tokens
# Tokens are generated per-user from the Settings UI and can authenticate the CLI.
# API_TOKEN_BYTES=32
# MAX_API_TOKENS_PER_USER=10
# MAX_API_TOKEN_NAME_LENGTH=100
# API_TOKEN_SESSION_DURATION_SECONDS=604800

# OAuth device flow for CLI login
# DEVICE_FLOW_CODE_TTL_SECONDS=900
# DEVICE_FLOW_POLL_INTERVAL_SECONDS=5
# RATE_LIMIT_DEVICE_CODE_CREATE=20
# RATE_LIMIT_DEVICE_POLL=360

# ========================================
# Trial Onboarding
# ========================================
# See docs/guides/trial-configuration.md for the full tunable list.
# TRIAL_MONTHLY_CAP=1500
# TRIAL_WORKSPACE_TTL_MS=1200000                # 20 min
# TRIAL_DATA_RETENTION_HOURS=168                # 7 days
# TRIAL_ANONYMOUS_USER_ID=system_anonymous_trials
# TRIAL_ANONYMOUS_INSTALLATION_ID=1
# TRIAL_AGENT_TYPE_STAGING=opencode
# TRIAL_AGENT_TYPE_PRODUCTION=claude-code
# TRIAL_DEFAULT_WORKSPACE_PROFILE=lightweight
# TRIAL_VM_SIZE=cax11
# TRIAL_VM_LOCATION=fsn1
# TRIALS_ENABLED_KV_KEY=trials:enabled
# TRIAL_REPO_MAX_KB=102400
# TRIAL_COUNTER_KEEP_MONTHS=6
# TRIAL_KILL_SWITCH_CACHE_MS=30000
# TRIAL_GITHUB_TIMEOUT_MS=10000
# TRIAL_EXPIRE_BATCH_SIZE=1000
# TRIAL_CLEANUP_BATCH_SIZE=25
# TRIAL_CLEANUP_DEADLINE_MS=45000
# TRIAL_NODE_DELETION_LOCK_STALE_MS=600000
# TRIAL_WAITLIST_PURGE_DAYS=90
# TRIAL_MODEL=@cf/qwen/qwen3-30b-a3b-fp8        # Model for trial conversations
# TRIAL_LLM_PROVIDER=workers-ai                 # "workers-ai" or "anthropic"
# ANTHROPIC_API_KEY_TRIAL=                       # Required only when TRIAL_LLM_PROVIDER=anthropic
# ENVIRONMENT=staging                            # "staging" or "production" — set by deploy pipeline
# TRIAL_SSE_HEARTBEAT_MS=15000
# TRIAL_SSE_POLL_TIMEOUT_MS=15000
# TRIAL_SSE_MAX_DURATION_MS=1800000
# TRIAL_CRON_ROLLOVER_CRON="0 5 1 * *"
# TRIAL_CRON_WAITLIST_CLEANUP="0 4 * * *"
# TRIAL_KNOWLEDGE_GITHUB_TIMEOUT_MS=10000
# TRIAL_KNOWLEDGE_MAX_EVENTS=50
# TRIAL_ORCHESTRATOR_OVERALL_TIMEOUT_MS=300000
# TRIAL_ORCHESTRATOR_STEP_MAX_RETRIES=5
# TRIAL_ORCHESTRATOR_RETRY_BASE_DELAY_MS=1000
# TRIAL_ORCHESTRATOR_RETRY_MAX_DELAY_MS=60000
# TRIAL_ORCHESTRATOR_NODE_READY_TIMEOUT_MS=180000
# TRIAL_ORCHESTRATOR_AGENT_READY_TIMEOUT_MS=60000
# TRIAL_ORCHESTRATOR_WORKSPACE_READY_TIMEOUT_MS=180000
# TRIAL_ORCHESTRATOR_WORKSPACE_READY_POLL_INTERVAL_MS=5000
# RATE_LIMIT_TRIAL_CREATE=10
# RATE_LIMIT_TRIAL_SSE=30

# ========================================
# AI Inference Proxy (Cloudflare AI Gateway)
# ========================================
# AI_PROXY_ENABLED=true
# AI_PROXY_DEFAULT_MODEL=@cf/qwen/qwen3-30b-a3b-fp8
# AI_GATEWAY_ID=sa379a6
# AI_PROXY_ALLOWED_MODELS=                       # Comma-separated; defaults in shared/constants
# AI_PROXY_RATE_LIMIT_RPM=60
# AI_PROXY_RATE_LIMIT_WINDOW_SECONDS=60
# AI_PROXY_MAX_INPUT_TOKENS_PER_REQUEST=4096
# AI_MONTHLY_COST_CACHE_TTL_SECONDS=7200
# Positive integer; invalid values fall back; hard cap 500
# AI_MONTHLY_COST_AGGREGATION_MAX_PAGES=200
# 1-50; invalid values fall back; values above 50 clamp to 50
# AI_USAGE_PAGE_SIZE=50
# Positive integer; invalid values fall back; hard cap 20
# AI_USAGE_MAX_PAGES=20

# Pages project names (for Worker proxy routing)
# PAGES_PROJECT_NAME=sa379a6-web-prod
# WWW_PAGES_PROJECT_NAME=sa379a6-www

# GitHub branch listing
# MAX_BRANCHES_PER_REPO=5000

# Files tab — remote-branch git browser + diff (GitHub + Artifacts)
# Max bytes to inline as text in the file viewer; larger files stream via rawUrl.
# REPO_BROWSE_MAX_INLINE_BYTES=1000000
# Max changed files returned by an Artifacts compare before truncating.
# REPO_BROWSE_MAX_COMPARE_FILES=300

# Resource limits
# MAX_NODES_PER_USER=10
# MAX_WORKSPACES_PER_NODE=3
# MAX_AGENT_SESSIONS_PER_WORKSPACE=10
# MAX_PROJECTS_PER_USER=100
# MAX_TASKS_PER_PROJECT=10000
# MAX_TASK_DEPENDENCIES_PER_TASK=50
# Project invite links
# PROJECT_INVITE_TOKEN_BYTES=32
# PROJECT_INVITE_DEFAULT_EXPIRY_DAYS=7
# PROJECT_INVITE_MAX_EXPIRY_DAYS=30
# TASK_LIST_DEFAULT_PAGE_SIZE=50
# TASK_LIST_MAX_PAGE_SIZE=200
# AGENT_SETTINGS_VALIDATION_LIMITS={"maxModelLength":200,"maxToolNameLength":200,"maxToolListLength":100,"maxEnvVars":50,"maxEnvKeyLength":128,"maxEnvValueLength":4096,"maxBaseUrlLength":2048}
# TASK_CALLBACK_TIMEOUT_MS=10000
# TASK_CALLBACK_RETRY_MAX_ATTEMPTS=3
# NODE_HEARTBEAT_STALE_SECONDS=180

# Missions (Phase 2: Orchestration Primitives)
# MISSION_MAX_PER_PROJECT=50
# MISSION_MAX_STATE_ENTRIES=200
# MISSION_MAX_HANDOFFS=100
# MISSION_TITLE_MAX_LENGTH=200
# MISSION_DESCRIPTION_MAX_LENGTH=5000
# MISSION_STATE_TITLE_MAX_LENGTH=200
# MISSION_STATE_CONTENT_MAX_LENGTH=2000
# HANDOFF_SUMMARY_MAX_LENGTH=5000
# HANDOFF_MAX_FACTS=50
# HANDOFF_MAX_OPEN_QUESTIONS=20
# HANDOFF_MAX_ARTIFACT_REFS=30
# HANDOFF_MAX_SUGGESTED_ACTIONS=20
# MISSION_LIST_PAGE_SIZE=20
# MISSION_LIST_MAX_PAGE_SIZE=100

# Content size limits
# MAX_TASK_MESSAGE_LENGTH=16000
# MAX_ACTIVITY_MESSAGE_LENGTH=2000
# MAX_LOG_MESSAGE_LENGTH=1000
# MAX_OUTPUT_SUMMARY_LENGTH=10000
# MAX_ACP_PROMPT_BYTES=262144
# MAX_ACP_CONTEXT_BYTES=262144
# MAX_MESSAGES_PER_BATCH=100
# MAX_MESSAGES_PAYLOAD_BYTES=262144
# MAX_AGENT_SESSION_LABEL_LENGTH=50

# Fresh-node readiness wait before first workspace provisioning (default: 600000ms / 10min)
# NODE_AGENT_READY_TIMEOUT_MS=600000
# NODE_AGENT_READY_POLL_INTERVAL_MS=5000

# AI task title generation (Workers AI via AI Gateway)
# TASK_TITLE_MODEL=@cf/zai-org/glm-4.7-flash
# TASK_TITLE_MAX_LENGTH=100
# TASK_TITLE_TIMEOUT_MS=5000
# TASK_TITLE_GENERATION_ENABLED=true
# TASK_TITLE_SHORT_MESSAGE_THRESHOLD=100
# TASK_TITLE_MAX_RETRIES=2
# TASK_TITLE_RETRY_DELAY_MS=1000
# TASK_TITLE_RETRY_MAX_DELAY_MS=4000

# Voice-to-text transcription (Workers AI)
# WHISPER_MODEL_ID=@cf/openai/whisper-large-v3-turbo
# MAX_AUDIO_SIZE_BYTES=10485760
# MAX_AUDIO_DURATION_SECONDS=60
# RATE_LIMIT_TRANSCRIBE=30

# Text-to-speech (Workers AI)
# TTS_ENABLED=true
# TTS_MODEL=@cf/deepgram/aura-2-en
# TTS_SPEAKER=luna
# TTS_ENCODING=mp3
# TTS_CLEANUP_MODEL=@cf/google/gemma-4-26b-a4b-it
# TTS_CLEANUP_MAX_TOKENS=4096
# TTS_MAX_TEXT_LENGTH=100000
# TTS_TIMEOUT_MS=60000
# TTS_CLEANUP_TIMEOUT_MS=15000
# TTS_R2_PREFIX=tts
# TTS_CHUNK_SIZE=1800
# TTS_MAX_CHUNKS=8
# TTS_SUMMARY_THRESHOLD=14400
# TTS_RETRY_ATTEMPTS=3
# TTS_RETRY_BASE_DELAY_MS=500

# Client-side error reporting
# RATE_LIMIT_CLIENT_ERRORS=200
# MAX_CLIENT_ERROR_BATCH_SIZE=25
# MAX_CLIENT_ERROR_BODY_BYTES=65536

# VM agent error reporting
# MAX_VM_AGENT_ERROR_BODY_BYTES=32768
# MAX_VM_AGENT_ERROR_BATCH_SIZE=10
# MAX_AGENT_CREDENTIAL_SYNC_BYTES=65536

# Browser sidecar proxy
# BROWSER_PROXY_TIMEOUT_MS=30000                      # Timeout for browser sidecar proxy requests (30s)

# Neko browser sidecar cloud-init configuration
# NEKO_IMAGE=ghcr.io/m1k1o/neko/google-chrome:latest  # Docker image for Neko browser sidecar
# NEKO_PRE_PULL=true                                   # Pre-pull Neko image during cloud-init (true/false)

# Hetzner base image override (optional). Default is 'docker-ce' — Hetzner's
# first-party marketplace image with Docker preinstalled, saving ~30-60s of
# apt-get time during provisioning. Set to 'ubuntu-24.04' (or any other valid
# Hetzner image slug) for emergency rollback without redeploy.
# HETZNER_BASE_IMAGE=ubuntu-24.04

# Hetzner capacity retry configuration (for transient 422 errors during VM provisioning)
# HETZNER_CAPACITY_RETRY_INITIAL_DELAY_MS=15000
# HETZNER_CAPACITY_RETRY_MAX_DELAY_MS=120000
# HETZNER_CAPACITY_RETRY_MAX_ATTEMPTS=5

# VM size fallback on transient capacity exhaustion (TaskRunner DO).
# When auto-provisioning a new node for a task fails with transient capacity
# exhaustion, descend the VM size chain (large -> medium -> small) and retry —
# but ONLY when the size was default-derived (project/platform default), never
# when a user explicitly requested a size. Default: enabled.
# CAPACITY_SIZE_FALLBACK_ENABLED=false    # set to "false" to disable size-fallback descent (kill switch)

# External API timeouts (milliseconds, default: 30000)
# HETZNER_API_TIMEOUT_MS=30000
# CF_API_TIMEOUT_MS=30000
# AGENT_CREDENTIAL_VALIDATION_TIMEOUT_MS=8000
# NODE_AGENT_REQUEST_TIMEOUT_MS=30000

# Workspace readiness (TaskRunner DO)
# TASK_RUNNER_WORKSPACE_READY_TIMEOUT_MS=1800000  # 30 minutes — max time for workspace-ready callback
# TASK_RUNNER_WORKSPACE_READY_POLL_INTERVAL_MS=30000  # 30 seconds — D1 poll interval during workspace_ready step
# PROVISIONING_TIMEOUT_MS=1800000                 # 30 minutes — cron marks 'creating' workspaces as error after this

# Docker daemon DNS for devcontainer builds (comma-separated quoted IPs)
# DOCKER_DNS_SERVERS="1.1.1.1", "8.8.8.8"

# Swap file configuration
# SWAP_SIZE_MB=2048              # Swap file size in MB (default: 2048, set to "0" to disable)
# SWAP_SWAPPINESS=60             # vm.swappiness value 0-100 (default: 60)

# Warm node pooling (NodeLifecycle DO)
# NODE_WARM_TIMEOUT_MS=1800000           # 30 minutes — how long warm nodes stay alive
# MAX_AUTO_NODE_LIFETIME_MS=14400000     # 4 hours — max lifetime for auto-provisioned nodes (skips active workspaces)
# NODE_WARM_GRACE_PERIOD_MS=2100000      # 35 minutes — cron sweep grace period (> warm timeout)
# NODE_LIFECYCLE_ALARM_RETRY_MS=60000    # 1 minute — retry delay for DO alarm failures

# Workspace idle timeout (ProjectData DO)
# WORKSPACE_IDLE_TIMEOUT_MS=7200000      # 2 hours — global default idle timeout before workspace is stopped (overridable per-project)
# WORKSPACE_STOPPED_TTL_MS=300000        # 5 minutes — auto-delete stopped workspaces after this TTL

# Durable Object RPC retry configuration (transient reset/overload errors)
# DO_RETRY_MAX_ATTEMPTS=8
# DO_RETRY_BASE_DELAY_MS=100
# DO_RETRY_MAX_DELAY_MS=250

# Task agent configuration
# DEFAULT_TASK_AGENT_TYPE=opencode     # Agent used for autonomous task execution

# MCP token configuration (agent platform awareness)
# MCP_TOKEN_TTL_SECONDS=28800             # 8 hours — inactivity timeout with sliding window (default: 8h)
# MCP_TOKEN_MAX_LIFETIME_SECONDS=86400    # 24 hours — hard cap regardless of activity (default: 24h)

# MCP HTTP-level rate limiting (per task/agent)
# MCP_RATE_LIMIT=120                      # Max requests per window (default: 120)
# MCP_RATE_LIMIT_WINDOW_SECONDS=60        # Rate limit window in seconds (default: 60)

# MCP dispatch_task limits (agent-to-agent task spawning)
# MCP_DISPATCH_MAX_DEPTH=3                # Max dispatch chain depth (0=user, 1=first agent dispatch, etc.)
# MCP_DISPATCH_MAX_PER_TASK=5             # Max tasks a single agent can dispatch
# MCP_DISPATCH_MAX_ACTIVE_PER_PROJECT=10  # Max concurrent agent-dispatched tasks per project
# MCP_DISPATCH_DESCRIPTION_MAX_LENGTH=32000  # Max description length for dispatched tasks
# MCP_DISPATCH_MAX_REFERENCES=20             # Max reference URLs per dispatched task
# MCP_DISPATCH_MAX_REFERENCE_LENGTH=500      # Max length per reference string
# MCP_DISPATCH_MAX_PRIORITY=100              # Max priority for agent-dispatched tasks

# Orchestration tools (agent-to-agent communication & control)
# ORCHESTRATOR_MAX_RETRIES_PER_TASK=3        # Max retry attempts per task via retry_subtask
# ORCHESTRATOR_DEPENDENCY_MAX_EDGES=50       # Max dependency edges per project via add_dependency
# ORCHESTRATOR_STOP_GRACE_MS=5000            # Grace period before hard stop after warning (ms)
# ORCHESTRATOR_MESSAGE_MAX_LENGTH=32768      # Max length for injected messages to child agents

# MCP get_session_messages limits
# MCP_MESSAGE_LIST_LIMIT=50              # Default number of raw tokens fetched per request
# MCP_MESSAGE_LIST_MAX=200               # Max raw tokens per request (before grouping into logical messages)

# MCP idea management limits
# MCP_IDEA_CONTENT_MAX_LENGTH=65536      # Max length for idea content/description (64 KB)
# MCP_IDEA_LIST_LIMIT=20                 # Default page size for list_ideas
# MCP_IDEA_LIST_MAX=100                  # Max page size for list_ideas
# MCP_IDEA_SEARCH_MAX=20                 # Max results for search_ideas
# MCP_IDEA_TITLE_MAX_LENGTH=200          # Max length for idea title
# MCP_SESSION_TOPIC_MAX_LENGTH=200       # Max length for session topic via update_session_topic

# Task execution timeout (stuck task recovery)
# TASK_RUN_MAX_EXECUTION_MS=14400000     # 4 hours — max time before task is failed
# TASK_STUCK_QUEUED_TIMEOUT_MS=600000      # 10 minutes — max time in 'queued' state
# TASK_STUCK_DELEGATED_TIMEOUT_MS=1860000  # 31 minutes — max time in 'delegated' state (> workspace ready timeout)
# CLAUDE_CODE_COMPACTION_LOOP_DETECTOR_ENABLED=true
# CLAUDE_CODE_COMPACTION_LOOP_RECENT_MESSAGE_LIMIT=40
# CLAUDE_CODE_COMPACTION_LOOP_WINDOW_MESSAGES=20
# CLAUDE_CODE_COMPACTION_LOOP_MIN_PAIRS=3

# Task reconciliation (inactivity check-in)
# TASK_RECONCILIATION_IDLE_MS=300000                    # 5 minutes — idle before visible SAM check-in
# TASK_RECONCILIATION_RESPONSE_DEADLINE_MS=60000         # 1 minute — response deadline after check-in
# TASK_RECONCILIATION_PROMPT_SOFT_STALL_MS=1800000       # 30 minutes — observe in-flight prompt without interrupting
# TASK_RECONCILIATION_PROMPT_HARD_STALL_MS=7200000       # 2 hours — cancel hard-stalled in-flight prompt before check-in retry
# TASK_RECONCILIATION_MIN_ALARM_DELAY_MS=10000           # 10 seconds — minimum delay before next reconciliation alarm
# SESSION_ACTIVITY_STALE_THRESHOLD_MS=300000             # 5 minutes — stale activity fallback threshold

# Cloudflare Account ID (required for historical log viewer, US3)
# CF_ACCOUNT_ID=

# Admin Observability (spec 023)
# OBSERVABILITY_ERROR_RETENTION_DAYS=30          # Days before purging old errors
# OBSERVABILITY_ERROR_MAX_ROWS=100000            # Max rows in platform_errors table
# OBSERVABILITY_ERROR_BATCH_SIZE=25              # Max errors per batch insert
# OBSERVABILITY_LOG_QUERY_RATE_LIMIT=30          # Max CF log queries per admin per minute
# OBSERVABILITY_STREAM_BUFFER_SIZE=1000          # Max entries in AdminLogs DO replay buffer
# OBSERVABILITY_STREAM_RECONNECT_DELAY_MS=1000   # Initial WebSocket reconnect delay
# OBSERVABILITY_STREAM_RECONNECT_MAX_DELAY_MS=30000  # Max WebSocket reconnect delay
# OBSERVABILITY_TREND_DEFAULT_RANGE_HOURS=24     # Default error trend time range

# ACP (Agent Communication Protocol) — VM Agent
# ACP_MESSAGE_BUFFER_SIZE=5000
# ACP_VIEWER_SEND_BUFFER=256
# ACP_STDERR_BUFFER_BYTES=4096
# ACP_PING_INTERVAL=30s
# ACP_PONG_TIMEOUT=10s
# ACP_PROMPT_TIMEOUT=0
# ACP_TASK_PROMPT_TIMEOUT=6h
# ACP_PROMPT_CANCEL_GRACE_PERIOD=5s
# ACP_PROMPT_RETRY_MAX_RETRIES=2
# ACP_PROMPT_RETRY_INITIAL_BACKOFF=15s
# ACP_PROMPT_RETRY_MAX_BACKOFF=2m
# ACTIVITY_REREPORT_INTERVAL=60s
# ACTIVITY_TERMINAL_REPORT_ATTEMPTS=5
# ACTIVITY_TERMINAL_REPORT_BACKOFF=1s
# ACP_IDLE_SUSPEND_TIMEOUT=30m
# ACP_NOTIF_SERIALIZE_TIMEOUT=5s
# ACP_INITIALIZE_TIMEOUT_MS=30000               # Per-phase timeout for ACP Initialize RPC (falls back to ACP_INIT_TIMEOUT_MS)
# ACP_NEW_SESSION_TIMEOUT_MS=30000              # Per-phase timeout for ACP NewSession RPC (falls back to ACP_INIT_TIMEOUT_MS)
# ACP_LOAD_SESSION_TIMEOUT_MS=15000             # Per-phase timeout for ACP LoadSession RPC (falls back to ACP_INIT_TIMEOUT_MS)

# ACP Session Lifecycle (spec 027 — DO-owned sessions)
# ACP_SESSION_DETECTION_WINDOW_MS=300000        # 5 min — heartbeat timeout before marking interrupted
# ACP_SESSION_MAX_FORK_DEPTH=10                 # Max fork chain depth
# Note: HEARTBEAT_INTERVAL_MS, RECONCILIATION_TIMEOUT_MS, FORK_CONTEXT_MESSAGES
# are defined in ACP_SESSION_DEFAULTS (packages/shared) but consumed by VM agent,
# not the API worker. They will be documented here when wired to the DO Env.

# Google INFRA OAuth (optional — only needed for GCP OIDC / deployment integration)
# GOOGLE_CLIENT_ID=                # Google Cloud Console OAuth 2.0 client ID (infra/GCP)
# GOOGLE_CLIENT_SECRET=            # Google Cloud Console OAuth 2.0 client secret (infra/GCP)
# Authorized redirect URIs to register in Google Cloud Console for this client:
#   https://api.<YOUR_BASE_DOMAIN>/api/deployment/gcp/callback
#   https://api.<YOUR_BASE_DOMAIN>/auth/google/callback
# These are single static URIs — no per-project URIs needed.

# Google LOGIN OAuth (optional env fallback — the /setup wizard is the primary path).
# A SEPARATE OAuth client from the infra one above, used for "Sign in with Google".
# GOOGLE_LOGIN_CLIENT_ID=          # Google login OAuth 2.0 client ID
# GOOGLE_LOGIN_CLIENT_SECRET=      # Google login OAuth 2.0 client secret
# Authorized redirect URI to register in Google Cloud Console for this client:
#   https://api.<YOUR_BASE_DOMAIN>/api/auth/callback/google

# GCP OIDC configuration defaults (all optional — sensible defaults provided)
# GCP_WIF_POOL_ID=sam-pool                    # Workload Identity Federation pool ID
# GCP_WIF_PROVIDER_ID=sam-oidc                # OIDC provider ID within the WIF pool
# GCP_SERVICE_ACCOUNT_ID=sam-vm-manager       # Service account created for VM management
# GCP_DEFAULT_ZONE=us-central1-a              # Default GCP zone for VM provisioning
# GCP_IMAGE_FAMILY=ubuntu-2404-lts-amd64      # VM image family
# GCP_IMAGE_PROJECT=ubuntu-os-cloud           # Image project
# GCP_DISK_SIZE_GB=50                         # Boot disk size in GB
# GCP_TOKEN_CACHE_TTL_SECONDS=3300            # STS token cache TTL (55 min, tokens expire at 60 min)
# GCP_IDENTITY_TOKEN_EXPIRY_SECONDS=600       # SAM→GCP identity token lifetime (10 min)
# GCP_OPERATION_POLL_TIMEOUT_MS=300000        # Max time to wait for GCP async operations (5 min)
# GCP_API_TIMEOUT_MS=30000                    # GCP API request timeout (30 sec)
# GCP_STS_SCOPE=https://www.googleapis.com/auth/cloud-platform  # OAuth scope for STS token exchange
# GCP_SA_IMPERSONATION_SCOPES=https://www.googleapis.com/auth/compute  # Comma-separated scopes for SA impersonation
# GCP_SA_TOKEN_LIFETIME_SECONDS=3600  # SA impersonation token lifetime (1 hour max)

# GCP deployment (project-level OIDC for Defang — all optional, sensible defaults provided)
# GCP_DEPLOY_WIF_POOL_ID=sam-deploy-pool                  # WIF pool ID for deployment auth
# GCP_DEPLOY_WIF_PROVIDER_ID=sam-oidc                     # OIDC provider ID within the deploy pool
# GCP_DEPLOY_SERVICE_ACCOUNT_ID=sam-deployer              # Service account for deployment operations
# GCP_DEPLOY_IDENTITY_TOKEN_EXPIRY_SECONDS=600            # SAM→GCP identity token lifetime (10 min)
# GCP_DEPLOY_OAUTH_STATE_TTL_SECONDS=600                  # OAuth CSRF state KV TTL (10 min)
# GCP_DEPLOY_OAUTH_TOKEN_HANDLE_TTL_SECONDS=300           # OAuth token handle KV TTL (5 min)
# GCP_STS_TOKEN_URL=https://sts.googleapis.com/v1/token   # GCP STS endpoint (override for VPC SC)
# GCP_IAM_CREDENTIALS_BASE_URL=https://iamcredentials.googleapis.com/v1/projects/-/serviceAccounts  # GCP IAM SA impersonation base

# VM agent TLS configuration
# VM_AGENT_PROTOCOL=https          # "https" (default) or "http" for non-TLS
# VM_AGENT_PORT=8443               # "8443" (default with TLS) or custom port
# ORIGIN_CA_CERT_VALIDITY_DAYS=7   # Per-node Origin CA certificate validity: 7, 30, 90, 365, 730, 1095, or 5475
# ORIGIN_CA_CERT=                  # Legacy only: old shared Origin CA certificate rotation input
# ORIGIN_CA_KEY=                   # Legacy only: old shared Origin CA private key rotation input

# App deployment route publishing (node-local loopback ports for Caddy)
# DEPLOY_PAYLOAD_EXPIRY_SECONDS=3600
# DEPLOYMENT_ROUTE_PORT_BASE=35000
# DEPLOYMENT_ROUTE_PORT_SPAN=100
# DOH_RESOLVER_URL=https://cloudflare-dns.com/dns-query
# DOH_TIMEOUT_MS=10000
# MAX_ENVIRONMENTS_PER_DEPLOYMENT_NODE=5
# DEPLOYMENT_DEFAULT_VM_SIZE=small
# DEPLOYMENT_MODEL_RUNNER_VM_SIZE=medium
# DEPLOYMENT_DEFAULT_MEMORY_LIMIT_MB=256
# DEPLOYMENT_LOG_MAX_SIZE=10m
# MCP_DEPLOYMENT_COMPOSE_PREVIEW_MAX_BYTES=128000
# DEPLOYMENT_LOG_MAX_FILE=3

# Project Data Durable Object limits
# MAX_SESSIONS_PER_PROJECT=10000
# MAX_MESSAGES_PER_SESSION=100000
# DOCUMENT_CARD_RAW_OUTPUT_MAX_BYTES=16384
# MESSAGE_SIZE_THRESHOLD=102400
# ACTIVITY_RETENTION_DAYS=90
# SESSION_IDLE_TIMEOUT_MINUTES=60
# DO_SUMMARY_SYNC_DEBOUNCE_MS=5000

# Analytics Engine (server-side usage tracking)
# ANALYTICS_ENABLED=true                          # Set to "false" to disable analytics writes
# ANALYTICS_SKIP_ROUTES=                          # Comma-separated additional route prefixes to skip
# ANALYTICS_SQL_API_URL=                          # Override CF Analytics Engine SQL API base URL
# ANALYTICS_DEFAULT_PERIOD_DAYS=30                # Default DAU query period
# ANALYTICS_DATASET=sa379a6_analytics              # Analytics Engine dataset name
# ANALYTICS_TOP_EVENTS_LIMIT=50                   # Max rows returned by top-events query
# ANALYTICS_GEO_LIMIT=50                           # Max countries in geo distribution query
# ANALYTICS_RETENTION_WEEKS=12                      # Retention cohort lookback weeks

# Analytics forwarding — external event export (Phase 4)
# ANALYTICS_FORWARD_ENABLED=false                   # Set to "true" to enable daily batch forwarding
# ANALYTICS_FORWARD_EVENTS=signup,login,project_created,workspace_created,task_submitted
# ANALYTICS_FORWARD_LOOKBACK_HOURS=25               # Hours of data to query per run (overlap for stragglers)
# ANALYTICS_FORWARD_CURSOR_KEY=analytics-forward-cursor  # KV key for last-forwarded timestamp
# SEGMENT_WRITE_KEY=                                # Segment write key (enables Segment forwarding)
# SEGMENT_API_URL=https://api.segment.io/v1/batch   # Segment batch endpoint
# SEGMENT_MAX_BATCH_SIZE=100                         # Max events per Segment batch
# GA4_MEASUREMENT_ID=                               # GA4 measurement ID (enables GA4 forwarding)
# GA4_API_SECRET=                                   # GA4 API secret
# GA4_API_URL=https://www.google-analytics.com/mp/collect  # GA4 Measurement Protocol endpoint
# GA4_MAX_BATCH_SIZE=25                              # Max events per GA4 request
# ANALYTICS_FORWARD_SQL_LIMIT=10000                  # Max rows per forwarding query
# ANALYTICS_SQL_FETCH_TIMEOUT_MS=30000               # Timeout for Analytics Engine SQL API fetch
# SEGMENT_FETCH_TIMEOUT_MS=30000                     # Timeout for Segment API fetch
# GA4_FETCH_TIMEOUT_MS=30000                         # Timeout for GA4 API fetch

# Chat compact mode (message size optimization)
# CHAT_COMPACT_MODE_DEFAULT=true                     # Strip tool_metadata.content on read path (default: true)
# CHAT_SESSION_MESSAGE_LIMIT=500                      # Default page size when no limit is requested — poll & load-more (default: 500)
# CHAT_SESSION_MESSAGE_MAX=50000                      # Ceiling any chat message request is clamped to — the initial full-conversation load requests up to this (default: 50000)

# File proxy configuration (chat file browser)
# FILE_PROXY_TIMEOUT_MS=15000                        # Timeout for VM agent file proxy requests (ms)
# FILE_PROXY_MAX_RESPONSE_BYTES=2097152              # Max response size for text file proxy (2MB)
# FILE_RAW_PROXY_MAX_BYTES=52428800                  # Max response size for binary/image file proxy (50MB)

# File upload/download proxy (Worker → VM agent)
# Note: Per-file size enforcement (FILE_UPLOAD_MAX_BYTES) is configured on the VM agent, not the Worker.
# FILE_UPLOAD_BATCH_MAX_BYTES=262144000              # Max total batch upload size forwarded to VM agent (250MB)
# FILE_UPLOAD_TIMEOUT_MS=120000                      # Timeout for upload proxy requests (ms)
# FILE_DOWNLOAD_TIMEOUT_MS=60000                     # Timeout for download proxy requests (ms)
# FILE_DOWNLOAD_MAX_BYTES=52428800                   # Max file download size forwarded from VM agent (50MB)
#
# VM agent file transfer settings (set via cloud-init, not Worker env):
# FILE_UPLOAD_MAX_BYTES=52428800                     # Max single file size (50MB) — VM agent only
# FILE_UPLOAD_BATCH_MAX_BYTES=262144000              # Max batch upload size (250MB) — VM agent only
# FILE_UPLOAD_TIMEOUT=120s                           # Upload operation timeout — VM agent only
# FILE_DOWNLOAD_TIMEOUT=60s                          # Download operation timeout — VM agent only
# FILE_DOWNLOAD_MAX_BYTES=52428800                   # Max download file size (50MB) — VM agent only

# Task attachment uploads (R2 presigned URLs)
# R2_ACCESS_KEY_ID=                                  # R2 S3-compatible Access Key ID (required for file attachments)
# R2_SECRET_ACCESS_KEY=                              # R2 S3-compatible Secret Access Key (required for file attachments)
# R2_BUCKET_NAME=                                    # R2 bucket name (set by deploy script)
# ATTACHMENT_UPLOAD_MAX_BYTES=52428800               # Max per-file attachment size (50MB)
# ATTACHMENT_UPLOAD_BATCH_MAX_BYTES=209715200        # Max total attachment batch size per task (200MB)
# ATTACHMENT_MAX_FILES=20                            # Max files per task submission
# ATTACHMENT_PRESIGN_EXPIRY_SECONDS=900              # Presigned URL expiry (15 min)
# ATTACHMENT_TRANSFER_TIMEOUT_MS=60000               # Timeout per attachment transfer to workspace (60s)

# Compose image artifact cleanup (R2-backed app deployment build artifacts only)
# COMPOSE_IMAGE_ARTIFACT_CLEANUP_ENABLED=true          # Set to false to disable abandoned artifact cleanup
# COMPOSE_IMAGE_ARTIFACT_ABANDONED_RETENTION_HOURS=48  # Keep unreferenced uploaded compose artifacts for this many hours
# COMPOSE_IMAGE_ARTIFACT_CLEANUP_BATCH_SIZE=50         # Max abandoned compose artifacts deleted per cleanup run
# COMPOSE_IMAGE_ARTIFACT_CLEANUP_INTERVAL_HOURS=24     # Minimum hours between R2 cleanup scans from cron
# COMPOSE_IMAGE_ARTIFACT_CLEANUP_LAST_RUN_KV_KEY=cleanup:compose-image-artifacts:last-run

# Account Map visualization
# ACCOUNT_MAP_MAX_ENTITIES=200                        # Max entities per type from D1 (default: 200)
# ACCOUNT_MAP_MAX_SESSIONS_PER_PROJECT=20             # Max sessions per project from DO fan-out (default: 20)
# ACCOUNT_MAP_CACHE_TTL_SECONDS=30                    # KV cache TTL for account map data (default: 30s)

# Notification Durable Object limits
# MAX_NOTIFICATIONS_PER_USER=500                      # Max stored notifications per user before oldest auto-deleted
# NOTIFICATION_AUTO_DELETE_AGE_MS=7776000000           # Auto-delete age (90 days)
# NOTIFICATION_PAGE_SIZE=50                            # Default page size for list requests
# NOTIFICATION_PROGRESS_BATCH_WINDOW_MS=300000         # Batch window for progress notifications (5 min)
# NOTIFICATION_DEDUP_WINDOW_MS=60000                   # Dedup window for task_complete notifications (60s)
# NOTIFICATION_FULL_BODY_LENGTH=5000                   # Max chars stored as fullMessage in notification metadata

# Project file library (per-project encrypted file storage)
# LIBRARY_ENCRYPTION_KEY=                              # Purpose-specific KEK for file library (falls back to ENCRYPTION_KEY)
# LIBRARY_UPLOAD_MAX_BYTES=52428800                    # Max file size per upload (50MB)
# LIBRARY_MAX_FILES_PER_PROJECT=500                    # Max files stored per project
# LIBRARY_MAX_TAGS_PER_FILE=20                         # Max tags per file
# LIBRARY_MAX_TAG_LENGTH=50                            # Max tag length in characters
# LIBRARY_MAX_FILENAME_LENGTH=255                      # Max filename length in characters
# LIBRARY_DOWNLOAD_TIMEOUT_MS=60000                    # Download timeout in milliseconds
# LIBRARY_KEY_VERSION=1                                # KEK version identifier (for key rotation)
# LIBRARY_LIST_DEFAULT_PAGE_SIZE=50                    # Default page size for file list
# LIBRARY_LIST_MAX_PAGE_SIZE=200                       # Max page size for file list
# LIBRARY_TAG_QUERY_BATCH_SIZE=80                      # File IDs per tag lookup query (kept below D1 bind-variable limit)

# Codex token refresh proxy (centralized OAuth token refresh)
# CODEX_REFRESH_PROXY_ENABLED=false                    # Kill switch: set "false" to disable (proxy is ENABLED by default)
# CODEX_REFRESH_LOCK_TIMEOUT_MS=30000                  # Per-user lock timeout (default: 30s)
# CODEX_REFRESH_UPSTREAM_URL=https://auth.openai.com/oauth/token  # OpenAI token endpoint
# CODEX_REFRESH_UPSTREAM_TIMEOUT_MS=10000              # Upstream request timeout (default: 10s)
# CODEX_CLIENT_ID=app_EMoamEEZ73f0CkXaXp7hrann        # OpenAI OAuth client_id
# RATE_LIMIT_CODEX_REFRESH_PER_HOUR=30                 # Max refresh requests per user per window (atomic via CodexRefreshLock DO; default: 30)
# RATE_LIMIT_CODEX_REFRESH_WINDOW_SECONDS=3600         # Rate limit window in seconds (default: 3600 = 1 hour)
# CODEX_EXPECTED_SCOPES=openid,profile,email,offline_access  # Allowlist of OAuth scopes upstream may return; unexpected scopes block refresh. Unset uses default allowlist; empty string disables validation.
# CODEX_REFRESH_GRACE_WINDOW_MS=300000                 # Grace window (ms) for recently-rotated tokens. Concurrent sessions holding a token rotated within this window still receive full tokens. Default: 300000 (5 min).

# Trigger execution cleanup (cron sweep)
# TRIGGER_STALE_EXECUTION_TIMEOUT_MS=1800000            # Timeout before running executions are considered stale (default: 30 min)
# TRIGGER_EXECUTION_LOG_RETENTION_DAYS=90               # Days to retain completed/failed/skipped execution logs (default: 90)
# TRIGGER_EXECUTION_CLEANUP_ENABLED=false               # Kill switch: set to "false" to disable cleanup sweep (default: enabled)
# TRIGGER_STALE_RECOVERY_BATCH_SIZE=100                 # Max stale executions to recover per sweep (default: 100)

# Durable Mailbox (Phase 1 orchestrator messaging)
# MAILBOX_ACK_TIMEOUT_MS=300000                            # Ack timeout before re-delivery (default: 5 min)
# MAILBOX_REDELIVERY_MAX_ATTEMPTS=5                        # Max delivery attempts before expiry (default: 5)
# MAILBOX_TTL_MS=3600000                                   # Default message TTL (default: 1 hour)
# MAILBOX_DELIVERY_POLL_INTERVAL_MS=30000                  # DO alarm sweep interval (default: 30 sec)
# MAILBOX_MAX_MESSAGES_PER_PROJECT=1000                    # Max active messages per project (default: 1000)
# MAILBOX_MESSAGE_MAX_LENGTH=32768                         # Max message content length (default: 32768)

# AI Inference Proxy (Workers AI gateway for trial/zero-config users)
# AI_PROXY_ENABLED=true                                    # Kill switch: set "false" to disable (default: enabled)
# AI_PROXY_DEFAULT_MODEL=@cf/meta/llama-4-scout-17b-16e-instruct  # Default model for OpenCode (override via admin UI or env var)
# AI_PROXY_DEFAULT_ANTHROPIC_MODEL=claude-sonnet-4-6  # Default model for Claude Code proxy fallback
# AI_PROXY_DEFAULT_OPENAI_MODEL=gpt-4.1              # Default model for Codex proxy fallback
# AI_PROXY_ALLOWED_MODELS=@cf/meta/llama-4-scout-17b-16e-instruct,claude-haiku-4-5-20251001,@cf/qwen/qwen3-30b-a3b-fp8,@cf/google/gemma-4-26b-a4b-it
# MODEL_CATALOG_SOURCE_URL=https://models.dev/api.json       # Dynamic OpenCode model catalog source
# MODEL_CATALOG_CACHE_TTL_SECONDS=3600                       # KV cache TTL for dynamic model catalogs
# MODEL_CATALOG_FETCH_TIMEOUT_MS=5000                        # Upstream model catalog fetch timeout
# AI_PROXY_DAILY_INPUT_TOKEN_LIMIT=500000                  # Per-user daily input token cap
# AI_PROXY_DAILY_OUTPUT_TOKEN_LIMIT=200000                 # Per-user daily output token cap
# AI_PROXY_MAX_INPUT_TOKENS_PER_REQUEST=32000              # Max input tokens per single request
# AI_PROXY_RATE_LIMIT_RPM=30                               # Requests per minute per user
# AI_PROXY_STREAM_TIMEOUT_MS=120000                        # Max streaming duration in ms
