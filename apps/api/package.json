{
  "name": "@simple-agent-manager/api",
  "version": "0.1.0",
  "private": true,
  "description": "Cloudflare Worker API for Simple Agent Manager",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "wrangler dev --port ${WRANGLER_PORT:-8787}",
    "test": "vitest run",
    "test:workers": "vitest run --config vitest.workers.config.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1033.0",
    "@aws-sdk/s3-request-presigner": "3.1033.0",
    "@cloudflare/sandbox": "^0.9.2",
    "@hono/node-server": "1.19.9",
    "@hono/valibot-validator": "0.6.1",
    "@mastra/core": "1.9.0",
    "@simple-agent-manager/cloud-init": "workspace:*",
    "@simple-agent-manager/providers": "workspace:*",
    "@simple-agent-manager/shared": "workspace:*",
    "ai": "6.0.168",
    "better-auth": "catalog:",
    "better-auth-cloudflare": "0.3.0",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.14",
    "jose": "6.2.2",
    "tsx": "catalog:",
    "valibot": "1.3.1",
    "workers-ai-provider": "3.1.11"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.14.0",
    "@cloudflare/workers-types": "catalog:",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "drizzle-kit": "0.26.2",
    "eslint": "catalog:",
    "execa": "catalog:",
    "fast-check": "4.7.0",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "wrangler": "catalog:"
  }
}
